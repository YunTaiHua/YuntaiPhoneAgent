# 环境配置文件
# 将此文件重命名为 .env 并放置在项目根目录
# 所有敏感信息和路径配置都应在此文件中管理

# ==================== GPT-SoVITS 配置 ====================
# GPT-SoVITS 根目录路径
GPT_SOVITS_ROOT=xxxxxxxxxxxxxxx

# ==================== 手机投屏配置 ====================
# Scrcpy 可执行文件路径
SCRCPY_PATH=xxxxxxxxxxxxxxxx

# ==================== AI 配置 ====================
# 智谱AI API 密钥（请替换为您的实际密钥）
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 音频处理配置 ====================
# FFmpeg 可执行文件路径
FFMPEG_PATH=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 文件路径配置 ====================
# 永久记忆文件路径
FOREVER_MEMORY_FILE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== Web 服务器配置 ====================
# Web 服务器监听地址
WEB_HOST=127.0.0.1
# Web 服务器监听端口
WEB_PORT=5000
# Web 调试模式
WEB_DEBUG=False
# 启动时自动打开浏览器
WEB_OPEN_BROWSER=True