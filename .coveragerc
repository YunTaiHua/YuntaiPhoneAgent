# .coveragerc - Coverage.py configuration
[run]
omit =
    yuntai/managers/gpt_sovits_custom/*
    yuntai/managers/tts_engine.py
    yuntai/handlers/*
    yuntai/gui/*
    yuntai/views/*

[report]
omit =
    yuntai/managers/gpt_sovits_custom/*
    yuntai/managers/tts_engine.py
    yuntai/handlers/*
    yuntai/gui/*
    yuntai/views/*